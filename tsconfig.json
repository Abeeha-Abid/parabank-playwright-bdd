{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",   // 👈 Fixes the tsconfig.json deprecation warning
    "resolveJsonModule": true,      // 👈 Fixes the "Cannot find module... .json" errors
    "sourceMap": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "**/*.ts", 
    "playwright.config.ts", 
    "DashboardReporter.ts"
  ]
}